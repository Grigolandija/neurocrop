PG_CONTAINER=postgresql
PGUSER=chirpstack
PGDATABASE=neurocrop
BACKUP_DATABASES=neurocrop chirpstack
BACKUP_DIR=/var/backups/neurocrop
BACKUP_RETENTION_DAYS=30

# Mount storage from another server or encrypted object-storage gateway here.
BACKUP_MIRROR_DIR=/mnt/neurocrop-offsite
RCLONE_REMOTE=neurocrop-r2-crypt:
RCLONE_CONFIG=/etc/neurocrop-rclone.conf
REQUIRE_OFFSITE_COPY=true
